select d.deptname, e.empname from department d join employees e on d.deptid=e.deptid where d.deptid>2 orderby d.deptname;
select d.deptname, e.empname from department d left outer join employees e on d.deptid=e.deptid where d.deptid>2 order by d.deptname;
select d.deptname, e.empname from department d right outer join employees e on d.deptid=e.deptid where d.deptid>2 order by d.deptname;
select d.deptname, e.empname from department d full outer join employees e on d.deptid=e.deptid where d.deptid>2 order by d.deptname;
select d.deptname, e.empname from department d cross join employees e where d.deptid>2 order by d.deptname;
